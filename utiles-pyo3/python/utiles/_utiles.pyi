@type_check_only
class TileDict(TypedDict):
    x: int
    y: int
    z: int

_TileLike: TypeAlias = Tile | tuple[int, int, int] | list[int] | int
_TileEncodingStr: TypeAlias = Literal[
    "uncompressed",
    "internal",
    "zlib",
    "gzip",
    "brotli",
    "zstd",
]
_TileFormatStr: TypeAlias = Literal[
    "png",
    "webp",
    "pbf",
    "mvt",
    "gif",
    "jpg",
    "jpeg",
    "json",
    "geojson",
]

_TileTypeContentEncodingHeader: TypeAlias = tuple[
    Literal["content-encoding"],
    Literal[
        "gzip",
        "deflate",
        "br",
        "zstd",
    ],
]
_TileTypeContentTypeHeader: TypeAlias = tuple[
    Literal["content-type"],
    Literal[
        "image/jpeg",
        "image/gif",
        "image/webp",
        "application/x-protobuf",
        "application/json",
        "application/geo+json",
        "image/tiff",
        "application/octet-stream",
    ],
]

_TileTypeHeaders: TypeAlias = list[
    _TileTypeContentTypeHeader | _TileTypeContentEncodingHeader
]

@final
class TileType:
    def __init__(self, format: _TileFormatStr, encoding: _TileEncodingStr) -> None: ...
    @property
    def format(self) -> _TileFormatStr: ...
    @property
    def encoding(self) -> _TileEncodingStr: ...
    @staticmethod
    def from_bytes(buf: bytes) -> TileType: ...
    def __eq__(self, other: Any, /) -> bool: ...
    @property
    def compression(self) -> _TileEncodingStr: ...
    @property
    def headers(self) -> _TileTypeHeaders: ...

@final
class LngLat:
    lat: float
    lng: float

    @classmethod
    def __init__(cls, lng: float, lat: float) -> None: ...
    @staticmethod
    def from_tile(tile: Tile) -> Any: ...
    def members(self) -> tuple[float, float]: ...
    def tuple(self) -> tuple[float, float]: ...
    def __eq__(self, other: Any, /) -> bool: ...
    def __ge__(self, other: Any, /) -> bool: ...
    def __getitem__(self, index: int, /) -> float: ...
    def __gt__(self, other: Any, /) -> bool: ...
    def __le__(self, other: Any, /) -> bool: ...
    def __len__(self) -> int: ...
    def __lt__(self, other: Any, /) -> bool: ...
    def __ne__(self, other: Any, /) -> bool: ...
    def __hash__(self) -> int: ...
    def __iter__(self) -> Iterator[float]: ...

@final
class Bbox:
    right: float
    top: float
    bottom: float
    left: float

    def __init__(
        self, right: float, top: float, left: float, bottom: float
    ) -> None: ...
    @classmethod
    def from_tile(cls, tile: Tile) -> Bbox: ...
    def members(self) -> tuple[float, float, float, float]: ...
    @overload
    def __getitem__(self, index: int, /) -> float: ...
    @overload
    def __getitem__(self, index: slice, /) -> tuple[float, ...]: ...
    def __len__(self) -> int: ...
    def __hash__(self) -> int: ...
    def __iter__(self) -> Iterator[float]: ...
    def tuple(self) -> tuple[float, float, float, float]: ...
    def __eq__(self, other: Any, /) -> bool: ...
    def __ge__(self, other: Any, /) -> bool: ...
    @property
    def east(self) -> float: ...
    @property
    def north(self) -> float: ...
    @property
    def south(self) -> float: ...
    @property
    def west(self) -> float: ...

@final
class LngLatBbox:
    east: float
    north: float
    south: float
    west: float

    def __init__(
        self, east: float, north: float, west: float, south: float
    ) -> None: ...
    @staticmethod
    def from_tile(tile: Tile) -> LngLatBbox: ...
    def members(self) -> tuple[float, float, float, float]: ...
    @overload
    def __getitem__(self, index: int, /) -> float: ...
    @overload
    def __getitem__(self, index: slice, /) -> tuple[float, ...]: ...
    def __len__(self) -> int: ...
    def __hash__(self) -> int: ...
    def __iter__(self) -> Iterator[float]: ...
    def tuple(self) -> tuple[float, float, float, float]: ...
    def __eq__(self, other: Any, /) -> bool: ...
    def __ge__(self, other: Any, /) -> bool: ...

@final
class Tile:
    def __init__(self, x: int, y: int, z: int) -> None: ...
    def bounds(self) -> LngLatBbox: ...
    def children(self, zoom: int = 1, zorder: bool = False) -> list[Tile]: ...
    def children1(self, zorder: bool = False) -> tuple[Tile, Tile, Tile, Tile]:
        """return direct children of the tile"""

    def flipy(self) -> Tile: ...
    @property
    def x(self) -> int: ...
    @property
    def y(self) -> int: ...
    @property
    def z(self) -> int: ...
    @staticmethod
    def from_lnglat_zoom(lng: float, lat: float, zoom: int) -> Tile: ...
    @staticmethod
    def from_quadkey(quadkey: str) -> Tile: ...
    @staticmethod
    def from_qk(qk: str) -> Tile: ...
    @staticmethod
    def from_pmtileid(pmtileid: int) -> Tile: ...
    @staticmethod
    def from_row_major_id(rmid: int) -> Tile: ...
    @staticmethod
    def from_rmid(rmid: int) -> Tile: ...
    def pmtileid(self) -> int: ...
    def parent_pmtileid(self) -> int: ...
    def row_major_id(self) -> tuple[int, int, int]: ...
    def rmid(self) -> tuple[int, int, int]: ...
    def json(self, *, obj: bool) -> str: ...
    def json_arr(self) -> str: ...
    def json_obj(self) -> str: ...
    def ll(self) -> LngLat: ...
    def lr(self) -> LngLat: ...
    def members(self) -> tuple[int, int, int]: ...
    def neighbors(self) -> list[Tile]: ...
    def parent(self) -> Tile: ...
    def siblings(self) -> list[Tile]: ...
    def ul(self) -> LngLat: ...
    def ur(self) -> LngLat: ...
    def __eq__(self, other: Any, /) -> bool: ...
    def __ge__(self, other: Tile | tuple[int, int, int], /) -> bool: ...
    def qk(self) -> str: ...
    def quadkey(self) -> str: ...
    def fmt_zxy(self, sep: str | None) -> str: ...
    def fmt_zxy_ext(self, ext: str, sep: str | None) -> str: ...
    @overload
    def __getitem__(self, index: int, /) -> int: ...
    @overload
    def __getitem__(self, index: slice, /) -> tuple[int, ...]: ...
    def __gt__(self, other: Tile, /) -> bool: ...
    def __invert__(self) -> Tile: ...
    def __le__(self, other: Tile, /) -> bool: ...
    def __len__(self) -> int: ...
    def __lt__(self, other: Tile, /) -> bool: ...
    def __ne__(self, other: Any, /) -> bool: ...
    def __hash__(self) -> int: ...
    def tuple(self) -> tuple[int, int, int]: ...
    def __iter__(self) -> Iterator[int]: ...
    def valid(self) -> bool: ...
    def asdict(self) -> TileDict: ...
    def feature(
        self,
        fid: str | None = ...,
        props: dict[Any, Any] | None = ...,
        projected: str | None = ...,
        buffer: float | None = ...,
        precision: int | None = ...,
    ) -> Any: ...
    def center(self) -> LngLat: ...

