{
  "compilerOptions": {
    "target": "ES2020",
    "baseUrl": ".",
    "module": "Node16",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["./fixtures/**/*.*"]
}
